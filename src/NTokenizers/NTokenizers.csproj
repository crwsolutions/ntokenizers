<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFrameworks>netstandard2.0</TargetFrameworks>
		<LangVersion>latest</LangVersion>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<IsPackable>true</IsPackable>

		<!-- NuGet package metadata -->
		<PackageId>NTokenizers</PackageId>
		<Version>6.1.1</Version>
		<Authors>crwsolutions</Authors>
		<Copyright>(c) crwsolutions</Copyright>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<Description>Collection of stream-capable tokenizers for XML, JSON, HTML, YAML, TOML, Markdown, TypeScript, CSS, C#, SQL, Java, C, C++, Rust, Kotlin, Go, Swift and Python processing. See README for usage and details.</Description>
		<PackageDescription>Collection of stream-capable tokenizers for XML, JSON, HTML, YAML, TOML, Markdown, TypeScript, CSS, C#, SQL, Java, C, C++, Rust, Kotlin, Go, Swift and Python processing. See README for usage and details.</PackageDescription>
		<PackageTags>tokenizer;xml;json;yaml;toml;md;markdown;typescript;javascript;css;c#;csharp;sql;java;c;c++;cpp;rust;kotlin;go;swift;python;stream;streaming;parse;parsing;dotnet</PackageTags>
		<RepositoryUrl>https://github.com/crwsolutions/ntokenizers</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<PackageProjectUrl>https://crwsolutions.github.io/ntokenizers</PackageProjectUrl>
		<Title>NTokenizers</Title>
		<PackageReleaseNotes>Updated icon</PackageReleaseNotes>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>
		<PackageIcon>icon.png</PackageIcon>
	</PropertyGroup>

	<ItemGroup>
		<None Include="..\..\README.md" Pack="true" PackagePath="\" />
		<None Include="..\..\art\icon.png" Pack="true" PackagePath="\" />
	</ItemGroup>

</Project>
